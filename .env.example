# Copy to .env (docker-compose reads it). All values have sane defaults in
# app/src/config.js; override here only when you want to change behaviour.

# --- Postgres ---
POSTGRES_USER=typeahead
POSTGRES_PASSWORD=typeahead
POSTGRES_DB=typeahead

# --- App ---
PORT=3000
# Inside docker-compose these hostnames resolve to the service names.
DATABASE_URL=postgres://typeahead:typeahead@postgres:5432/typeahead
REDIS_URL=redis://redis:6379

# --- Consistent hashing / logical cache nodes ---
CACHE_NODES=cache-a,cache-b,cache-c
VNODES_PER_NODE=150

# --- Cache ---
CACHE_TTL_SECONDS=300
SUGGEST_LIMIT=10
MAX_CACHEABLE_PREFIX_LEN=32

# --- Write buffer / flusher ---
QUEUE_KEY=search:queue
FLUSH_INTERVAL_MS=5000
FLUSH_MAX_BATCH=1000

# --- Trending (forward exponential decay) ---
DECAY_FACTOR=0.85
# Fixed reference date for forward-decay weights (must stay stable).
DECAY_EPOCH=2026-06-01
# Reconciliation interval (trending stays live via the flusher regardless).
DECAY_INTERVAL_MS=3600000

# --- Instrumentation ---
LATENCY_WINDOW=1000
